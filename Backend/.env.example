# ==========================================
# SkillGap AI Copilot Backend - Environment Template (.env.example)
# Copy this file to .env and replace placeholders with active credentials.
# ==========================================

# Environment & Server Config
NODE_ENV=development
PORT=5000
APP_SECRET=your_app_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------
# AI Provider API Credentials
# ------------------------------------------

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
GOOGLE_API_KEY=your_google_generative_api_key_here

# Default AI Provider (openai | gemini)
DEFAULT_API_PROVIDER=gemini

# Default Model (e.g. gpt-4o or gemini-1.5-flash)
DEFAULT_API_MODEL=gemini-1.5-flash

# ------------------------------------------
# AI System & Capture Settings
# ------------------------------------------
SYSTEM_PROMPT="You are an expert AI Interview Copilot. Your task is to analyze the interview screenshot and live audio transcription to provide concise, structured guidance, code snippets, and key talking points."

CAPTURE_INTERVAL_SECONDS=5
CAPTURE_SOURCE=default
MAX_CAPTURE_WIDTH=1280
MAX_CAPTURE_HEIGHT=720

# ------------------------------------------
# Firebase Configuration
# ------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
