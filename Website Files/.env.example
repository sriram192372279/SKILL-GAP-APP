# ==========================================
# SkillGap Web Application - Environment Template (.env.example)
# Copy this file to .env and fill in your actual values.
# ==========================================

# Application Config
VITE_APP_NAME=SkillGap
VITE_APP_TITLE="SkillGap - AI Skill Evaluation & Job Intelligence Platform"
VITE_APP_URL=http://localhost:5173
VITE_ENVIRONMENT=development

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=15000

# Firebase Configuration (Replace with your Firebase project credentials)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_FIREBASE_AUTH=true
VITE_ENABLE_AI_COPILOT=true
VITE_ENABLE_MOCK_DATA=true

# AI Service Settings
VITE_DEFAULT_AI_PROVIDER=gemini
VITE_DEFAULT_AI_MODEL=gemini-1.5-flash
